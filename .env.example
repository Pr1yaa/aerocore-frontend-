# ─────────────────────────────────────────────────────
# CrewOps · Frontend Environment Variables
# Copy to .env.local and fill in your values.
# ─────────────────────────────────────────────────────

# ── Supabase (required for live data + realtime) ──────
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://add-link.supabase.co
VITE_SUPABASE_ANON_KEY=ADD-KEY-HERE

# ── Backend API base (required for message send, leave approve/reject, task status) ──
# Set to your FastAPI / Express server root when backend is deployed.
# Leave blank to use mock/optimistic-only mode.
VITE_API_BASE_URL=http://ac1backend.netlify.app/

# ─────────────────────────────────────────────────────
# When VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY are absent:
#   → App falls back to mock data (no realtime)
# When VITE_API_BASE_URL is absent:
#   → Sends are optimistic-only (no server persistence)
# ─────────────────────────────────────────────────────
